# Runtime directory for howdy daemon socket
d /run/howdy 0755 root howdy -

# Data directory (biometric data - restricted)
d /var/lib/howdy 0750 root howdy -
d /var/lib/howdy/models 0755 root root -

# Log directory (auth snapshots - restricted)
d /var/log/howdy 0750 root howdy -
d /var/log/howdy/snapshots 0750 root howdy -
