# Maintainer: visage contributors
pkgname=visage
pkgver=0.1.0
pkgrel=1
pkgdesc="Face authentication for Linux"
arch=('x86_64')
url="https://github.com/user/visage"
license=('MIT')
depends=('pam' 'gcc-libs')
makedepends=('rust' 'cargo' 'clang')
optdepends=('tpm2-tss: TPM2 support for embedding encryption')
backup=('etc/visage/config.toml')
install=visage.install

build() {
    cd "$srcdir/$pkgname-$pkgver"
    cargo build --release --workspace
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Binary (unified)
    install -Dm755 target/release/visage "$pkgdir/usr/bin/visage"

    # PAM module (Arch uses /usr/lib/security/)
    install -Dm755 target/release/libpam_visage.so "$pkgdir/usr/lib/security/pam_visage.so"

    # Configuration
    install -Dm644 config/visage.toml "$pkgdir/etc/visage/config.toml"

    # systemd units
    install -Dm644 systemd/visage-daemon.service "$pkgdir/usr/lib/systemd/system/visage-daemon.service"
    install -Dm644 systemd/visage-daemon.socket "$pkgdir/usr/lib/systemd/system/visage-daemon.socket"

    # sysusers.d for visage group
    install -Dm644 dist/visage.sysusers "$pkgdir/usr/lib/sysusers.d/visage.conf"

    # tmpfiles.d for runtime directories
    install -Dm644 dist/visage.tmpfiles "$pkgdir/usr/lib/tmpfiles.d/visage.conf"

    # Data directories
    install -dm750 "$pkgdir/var/lib/visage"
    install -dm755 "$pkgdir/var/lib/visage/models"
    install -dm750 "$pkgdir/var/log/visage"
    install -dm750 "$pkgdir/var/log/visage/snapshots"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
