FROM archlinux:latest

# Install dependencies
RUN pacman -Syu --noconfirm pam sudo base-devel libxkbcommon && pacman -Scc --noconfirm

# Build pamtester from upstream source
RUN curl -sL https://sourceforge.net/projects/pamtester/files/pamtester/0.1.2/pamtester-0.1.2.tar.gz/download | tar xz -C /tmp && \
    cd /tmp/pamtester-0.1.2 && \
    ./configure --prefix=/usr CFLAGS="-Wno-implicit-function-declaration" && make && make install && \
    rm -rf /tmp/pamtester-0.1.2

# Create test user
RUN useradd -m testuser && echo "testuser:test" | chpasswd

# Copy built artifacts
COPY target/release/libpam_visage.so /lib/security/pam_visage.so
COPY target/release/visage-daemon /usr/bin/visage-daemon
COPY target/release/visage /usr/bin/visage
COPY test/pam.d/visage-test /etc/pam.d/visage-test

# Create config directory and copy dev config
RUN mkdir -p /etc/visage
COPY dev/config.toml /etc/visage/config.toml

# Copy models for integration tests
COPY models/*.onnx /models/
COPY models/manifest.toml /models/manifest.toml

# Copy test scripts
COPY test/run-container-tests.sh /run-tests.sh
COPY test/run-integration-tests.sh /run-integration-tests.sh
RUN chmod +x /run-tests.sh /run-integration-tests.sh

CMD ["/run-tests.sh"]
